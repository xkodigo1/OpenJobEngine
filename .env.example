ASPNETCORE_ENVIRONMENT=Development
Persistence__Provider=Sqlite
Persistence__ApplyMigrationsOnStartup=true
ConnectionStrings__Sqlite=Data Source=openjobengine.db
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=openjobengine;Username=postgres;Password=postgres
ApiSecurity__Enabled=false
ApiSecurity__HeaderName=X-Api-Key
ApiSecurity__ApiKey=
Providers__Greenhouse__Enabled=false
Providers__Greenhouse__BoardToken=
Providers__Greenhouse__StaleAfterHours=168
Providers__Lever__Enabled=false
Providers__Lever__Site=
Providers__Lever__CompanyName=
Providers__Lever__PageSize=100
Providers__Lever__MaxPages=10
Providers__Lever__StaleAfterHours=168
Providers__Computrabajo__Enabled=false
Providers__Computrabajo__SearchTerm=developer
Providers__Computrabajo__MaxPages=2
Providers__Computrabajo__UsePlaywright=false
Providers__Computrabajo__StaleAfterHours=72
Providers__Adzuna__Enabled=false
Providers__Adzuna__CountryCode=co
Providers__Adzuna__SearchTerm=developer
Providers__Adzuna__Location=bogota
Providers__Adzuna__AppId=
Providers__Adzuna__AppKey=
Providers__Adzuna__StaleAfterHours=72
Worker__Enabled=false
Worker__IntervalMinutes=60
Worker__RunOnStartup=false
Worker__MaxConcurrentSources=1
Worker__RetryCount=2
Worker__RetryInitialDelaySeconds=10
Worker__RetryBackoffMultiplier=2.0
Worker__ProviderTimeoutSeconds=300
Worker__SkipIfAlreadyRunning=true
Worker__DispatchAlertsAfterCollection=true
Worker__OnlyDispatchAlertsWhenAnyCollectionSucceeded=true
