{
  "Persistence": {
    "Provider": "Sqlite",
    "ApplyMigrationsOnStartup": true
  },
  "ConnectionStrings": {
    "Sqlite": "Data Source=openjobengine.db",
    "Postgres": "Host=localhost;Port=5432;Database=openjobengine;Username=postgres;Password=postgres"
  },
  "Worker": {
    "Enabled": false,
    "IntervalMinutes": 60,
    "RunOnStartup": false,
    "SourceName": null,
    "MaxConcurrentSources": 1,
    "RetryCount": 2,
    "RetryInitialDelaySeconds": 10,
    "RetryBackoffMultiplier": 2.0,
    "SkipIfAlreadyRunning": true,
    "DispatchAlertsAfterCollection": true
  },
  "Providers": {
    "Computrabajo": {
      "Enabled": false,
      "SourceName": "computrabajo",
      "BaseUrl": "https://www.computrabajo.com.co",
      "SearchTerm": "developer",
      "MaxPages": 1,
      "DelayMs": 1000,
      "UsePlaywright": false,
      "UserAgent": "OpenJobEngine/1.0 (+https://github.com)",
      "StaleAfterHours": 72
    },
    "Adzuna": {
      "Enabled": false,
      "SourceName": "adzuna",
      "BaseUrl": "https://api.adzuna.com/v1/api/jobs",
      "CountryCode": "co",
      "SearchTerm": "developer",
      "Location": "bogota",
      "Page": 1,
      "ResultsPerPage": 20,
      "AppId": "",
      "AppKey": "",
      "StaleAfterHours": 72
    },
    "Greenhouse": {
      "Enabled": false,
      "SourceName": "greenhouse",
      "BaseUrl": "https://boards-api.greenhouse.io/v1/boards",
      "BoardToken": "",
      "IncludeContent": true,
      "StaleAfterHours": 168
    },
    "Lever": {
      "Enabled": false,
      "SourceName": "lever",
      "BaseUrl": "https://api.lever.co/v0/postings",
      "Site": "",
      "CompanyName": "",
      "PageSize": 100,
      "MaxPages": 10,
      "StaleAfterHours": 168
    }
  }
}
