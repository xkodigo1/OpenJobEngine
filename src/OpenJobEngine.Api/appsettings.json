{
  "Persistence": {
    "Provider": "Sqlite",
    "ApplyMigrationsOnStartup": true
  },
  "ApiSecurity": {
    "Enabled": false,
    "HeaderName": "X-Api-Key",
    "ApiKey": ""
  },
  "ConnectionStrings": {
    "Sqlite": "Data Source=openjobengine.db",
    "Postgres": "Host=localhost;Port=5432;Database=openjobengine;Username=postgres;Password=postgres"
  },
  "Providers": {
    "Computrabajo": {
      "Enabled": false,
      "SourceName": "computrabajo",
      "BaseUrl": "https://www.computrabajo.com.co",
      "SearchTerm": "developer",
      "MaxPages": 1,
      "DelayMs": 1000,
      "UsePlaywright": false,
      "UserAgent": "OpenJobEngine/1.0 (+https://github.com)"
    },
    "Adzuna": {
      "Enabled": false,
      "SourceName": "adzuna",
      "BaseUrl": "https://api.adzuna.com/v1/api/jobs",
      "CountryCode": "co",
      "SearchTerm": "developer",
      "Location": "bogota",
      "Page": 1,
      "ResultsPerPage": 20,
      "AppId": "",
      "AppKey": ""
    },
    "Greenhouse": {
      "Enabled": false,
      "SourceName": "greenhouse",
      "BaseUrl": "https://boards-api.greenhouse.io/v1/boards",
      "BoardToken": "",
      "IncludeContent": true
    }
  }
}
